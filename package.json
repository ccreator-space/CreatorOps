{
  "name": "shipin-social-content-calendar",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @shipin/web --filter @shipin/api dev",
    "build": "pnpm -r --if-present build",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm --filter @shipin/db build && pnpm -r --if-present typecheck",
    "db:generate": "pnpm --filter @shipin/db db:generate",
    "db:migrate": "pnpm --filter @shipin/db db:migrate",
    "db:deploy": "pnpm --filter @shipin/db db:deploy",
    "db:seed": "pnpm --filter @shipin/db db:seed",
    "db:studio": "pnpm --filter @shipin/db db:studio"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
