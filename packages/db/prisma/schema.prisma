generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  user
}

enum ContentPlatform {
  linkedin
  instagram
}

enum PostStatus {
  draft
  pending_review
  approved
  rejected
  revision_requested
}

model User {
  id           String               @id @default(cuid())
  name         String
  email        String               @unique
  role         UserRole             @default(user)
  avatarUrl    String?
  assignments  CalendarAssignment[]
  posts        SocialPost[]         @relation("PostAuthor")
  reviewEvents ReviewEvent[]        @relation("ReviewActor")
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

model CalendarAssignment {
  id     String   @id @default(cuid())
  date   DateTime
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts  SocialPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([userId])
}

model SocialPost {
  id           String          @id @default(cuid())
  platform     ContentPlatform
  title        String
  content      String
  status       PostStatus      @default(pending_review)
  scheduledFor DateTime
  authorId     String
  assignmentId String?

  author     User                @relation("PostAuthor", fields: [authorId], references: [id])
  assignment CalendarAssignment? @relation(fields: [assignmentId], references: [id])
  reviews    ReviewEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([scheduledFor])
  @@index([authorId])
}

model ReviewEvent {
  id        String     @id @default(cuid())
  postId    String
  actorId   String
  status    PostStatus
  note      String?
  post      SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  actor     User       @relation("ReviewActor", fields: [actorId], references: [id])
  createdAt DateTime   @default(now())

  @@index([postId])
  @@index([actorId])
}

