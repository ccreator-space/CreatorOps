generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  user
}

enum ContentPlatform {
  linkedin
  instagram
}

enum PostStatus {
  draft
  pending_review
  approved
  rejected
  revision_requested
}

enum AttachmentType {
  image
  pdf
}

enum SubmissionType {
  builder_spotlight
  project_highlight
  readme_book
}

enum SubmissionStatus {
  new
  assigned
  in_progress
  approved
  rejected
  archived
}

enum FormQuestionType {
  text
  textarea
  range
  media
  url
  email
  number
  select
  checkbox
}

model User {
  id           String               @id @default(cuid())
  name         String
  email        String               @unique
  passwordHash String
  role         UserRole             @default(user)
  isActive     Boolean              @default(true)
  avatarUrl    String?
  avatarStoragePath String?
  assignments  CalendarAssignment[]
  posts        SocialPost[]                  @relation("PostAuthor")
  contentIdeas ContentIdea[]                 @relation("ContentIdeaCreator")
  reviewEvents ReviewEvent[]                 @relation("ReviewActor")
  assignedSubmissions Submission[]           @relation("SubmissionAssignee")
  seriesAssignments SubmissionSeriesAssignment[]
  createdAt    DateTime                      @default(now())
  updatedAt    DateTime                      @updatedAt

  @@index([isActive])
}

model AppSettings {
  id              String   @id @default("app-settings")
  logoUrl         String?
  logoStoragePath String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Series {
  id          String                       @id @default(cuid())
  slug        String                       @unique
  title       String
  description String
  isActive    Boolean                      @default(true)
  legacyType  SubmissionType?              @unique
  forms       SubmissionForm[]
  submissions Submission[]
  assignments SubmissionSeriesAssignment[]
  createdAt   DateTime                     @default(now())
  updatedAt   DateTime                     @updatedAt

  @@index([isActive])
}

model CalendarAssignment {
  id     String   @id @default(cuid())
  date   DateTime
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts  SocialPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([userId])
}

model SocialPost {
  id           String          @id @default(cuid())
  platform     ContentPlatform
  title        String
  content      String
  status       PostStatus      @default(pending_review)
  scheduledFor DateTime
  authorId     String
  assignmentId String?

  author     User                @relation("PostAuthor", fields: [authorId], references: [id])
  assignment CalendarAssignment? @relation(fields: [assignmentId], references: [id])
  reviews    ReviewEvent[]
  attachments PostAttachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([scheduledFor])
  @@index([authorId])
}

model ContentIdea {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  createdById String
  createdBy   User     @relation("ContentIdeaCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([createdById])
}

model PostAttachment {
  id                  String         @id @default(cuid())
  postId              String
  type                AttachmentType
  originalName        String
  mimeType            String
  sizeBytes           Int
  compressedSizeBytes Int?
  width               Int?
  height              Int?
  storagePath         String
  publicUrl           String
  sortOrder           Int            @default(0)
  post                SocialPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt           DateTime       @default(now())

  @@index([postId])
}

model ReviewEvent {
  id        String     @id @default(cuid())
  postId    String
  actorId   String
  status    PostStatus
  note      String?
  post      SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  actor     User       @relation("ReviewActor", fields: [actorId], references: [id])
  createdAt DateTime   @default(now())

  @@index([postId])
  @@index([actorId])
}

model Submission {
  id                  String                 @id @default(cuid())
  formId              String?
  seriesId            String?
  type                SubmissionType?
  status              SubmissionStatus       @default(new)
  submitterFirstName  String
  submitterLastName   String
  submitterEmail      String
  submitterLinkedin   String
  note                String?
  payload             Json
  assignedToId        String?
  form                SubmissionForm?        @relation(fields: [formId], references: [id], onDelete: SetNull)
  series              Series?                @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  assignedTo          User?                  @relation("SubmissionAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  attachments         SubmissionAttachment[]
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@index([formId])
  @@index([seriesId])
  @@index([type])
  @@index([status])
  @@index([assignedToId])
  @@index([createdAt])
}

model SubmissionAttachment {
  id                  String         @id @default(cuid())
  submissionId        String
  questionKey         String?
  type                AttachmentType
  originalName        String
  mimeType            String
  sizeBytes           Int
  compressedSizeBytes Int?
  width               Int?
  height              Int?
  storagePath         String
  publicUrl           String
  sortOrder           Int            @default(0)
  submission          Submission     @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  createdAt           DateTime       @default(now())

  @@index([submissionId])
}

model SubmissionForm {
  id          String                   @id @default(cuid())
  slug        String                   @unique
  title       String
  description String
  seriesId    String?
  seriesType  SubmissionType?
  isActive    Boolean                  @default(true)
  series      Series?                  @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  questions   SubmissionFormQuestion[]
  submissions Submission[]
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@index([seriesId])
  @@index([seriesType])
  @@index([isActive])
}

model SubmissionFormQuestion {
  id          String           @id @default(cuid())
  formId      String
  key         String
  label       String
  description String?
  type        FormQuestionType
  required    Boolean          @default(false)
  sortOrder   Int              @default(0)
  placeholder String?
  helpText     String?
  config      Json?
  form        SubmissionForm   @relation(fields: [formId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([formId, key])
  @@index([formId])
}

model SubmissionSeriesAssignment {
  id         String         @id @default(cuid())
  seriesId   String
  seriesType SubmissionType?
  userId     String
  series     Series         @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([seriesId, userId])
  @@index([seriesId])
  @@index([seriesType])
  @@index([userId])
}
