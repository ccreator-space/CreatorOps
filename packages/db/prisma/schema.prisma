generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  user
}

enum ContentPlatform {
  linkedin
  instagram
}

enum PostStatus {
  draft
  pending_review
  approved
  rejected
  revision_requested
}

enum AttachmentType {
  image
  pdf
}

enum SubmissionType {
  builder_spotlight
  project_highlight
  readme_book
}

enum SubmissionStatus {
  new
  assigned
  in_progress
  approved
  rejected
  archived
}

model User {
  id           String               @id @default(cuid())
  name         String
  email        String               @unique
  passwordHash String
  role         UserRole             @default(user)
  avatarUrl    String?
  assignments  CalendarAssignment[]
  posts        SocialPost[]                  @relation("PostAuthor")
  reviewEvents ReviewEvent[]                 @relation("ReviewActor")
  assignedSubmissions Submission[]           @relation("SubmissionAssignee")
  seriesAssignments SubmissionSeriesAssignment[]
  createdAt    DateTime                      @default(now())
  updatedAt    DateTime                      @updatedAt
}

model CalendarAssignment {
  id     String   @id @default(cuid())
  date   DateTime
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts  SocialPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([userId])
}

model SocialPost {
  id           String          @id @default(cuid())
  platform     ContentPlatform
  title        String
  content      String
  status       PostStatus      @default(pending_review)
  scheduledFor DateTime
  authorId     String
  assignmentId String?

  author     User                @relation("PostAuthor", fields: [authorId], references: [id])
  assignment CalendarAssignment? @relation(fields: [assignmentId], references: [id])
  reviews    ReviewEvent[]
  attachments PostAttachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([scheduledFor])
  @@index([authorId])
}

model PostAttachment {
  id                  String         @id @default(cuid())
  postId              String
  type                AttachmentType
  originalName        String
  mimeType            String
  sizeBytes           Int
  compressedSizeBytes Int?
  width               Int?
  height              Int?
  storagePath         String
  publicUrl           String
  sortOrder           Int            @default(0)
  post                SocialPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt           DateTime       @default(now())

  @@index([postId])
}

model ReviewEvent {
  id        String     @id @default(cuid())
  postId    String
  actorId   String
  status    PostStatus
  note      String?
  post      SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  actor     User       @relation("ReviewActor", fields: [actorId], references: [id])
  createdAt DateTime   @default(now())

  @@index([postId])
  @@index([actorId])
}

model Submission {
  id                  String                 @id @default(cuid())
  type                SubmissionType
  status              SubmissionStatus       @default(new)
  submitterFirstName  String
  submitterLastName   String
  submitterEmail      String
  submitterLinkedin   String
  note                String?
  payload             Json
  assignedToId        String?
  assignedTo          User?                  @relation("SubmissionAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  attachments         SubmissionAttachment[]
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@index([type])
  @@index([status])
  @@index([assignedToId])
  @@index([createdAt])
}

model SubmissionAttachment {
  id                  String         @id @default(cuid())
  submissionId        String
  type                AttachmentType
  originalName        String
  mimeType            String
  sizeBytes           Int
  compressedSizeBytes Int?
  width               Int?
  height              Int?
  storagePath         String
  publicUrl           String
  sortOrder           Int            @default(0)
  submission          Submission     @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  createdAt           DateTime       @default(now())

  @@index([submissionId])
}

model SubmissionSeriesAssignment {
  id         String         @id @default(cuid())
  seriesType SubmissionType
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([seriesType, userId])
  @@index([seriesType])
  @@index([userId])
}
